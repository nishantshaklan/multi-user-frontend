# Keycloak (required for production / standalone login)
VITE_KEYCLOAK_URL=https://keycloak.showroom.lumegalabs.com
VITE_KEYCLOAK_REALM=converse
VITE_KEYCLOAK_CLIENT=converse-client

# Local dev only — paste a valid bearer token here to skip Keycloak redirect.
# Use this when running on localhost:3000 without the Converse host.
# VITE_DEV_ACCESS_TOKEN=

# Multi-user API (list, invite, deactivate — see FRONTEND_API.md §1)
VITE_MULTI_USER_API_URL=https://converse.showroom.lumegalabs.com/multi-user-api

# Optional: server-side invite key for environments that require it
# VITE_INVITE_API_KEY=

# Ladder plan API — USER LIMIT banner (see FRONTEND_API.md §4.0)
VITE_PlAN_BASE_URL=https://converse.showroom.lumegalabs.com/ladder-api/v1

# Dev server port (optional)
# PORT=3000

# SonarQube (local analysis — see docker-sonarqube.sh)
# SONAR_TOKEN=
